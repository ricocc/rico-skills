# Rico-Skills Screenshot Configuration
#
# This file contains API keys for screenshot services.
# 
# HOW TO USE:
# 1. Copy this file to .rico-skills/.env
# 2. Fill in your API keys below
# 3. Save the file
# 
# ALTERNATIVE: Let the skill create this file for you!
# When you request screenshots, choose "Create .env file" option
# and the skill will guide you through the setup.
#
# IMPORTANT: Never commit .env file to version control!

# ============================================
# Default Screenshot Service
# ============================================
# Choose which service to use by default when you reply "yes"
# Options: screenshotone | urlscan
# - screenshotone: Fast (2-5s), 100/month free, requires API key
# - urlscan: Slower (10-30s), 5,000 Public/day free, requires API key
SCREENSHOT_DEFAULT_SERVICE=screenshotone

# ============================================
# Screenshot Dimensions
# ============================================
# Default screenshot size (width x height)
# Format: WIDTHxHEIGHT (e.g., 1600x900, 1920x1080)
# Common sizes:
# - 1920x1080 (16:9) - Full HD
# - 1600x900 (16:9) - Blog posts (RECOMMENDED)
# - 1440x900 (16:10) - Mac displays
# - 1200x800 (3:2) - Tablets
# Note: urlscan.io may ignore this and use standard sizes
SCREENSHOT_DEFAULT_SIZE=1600x900

# ============================================
# ScreenshotOne API Key
# ============================================
# Get your free API key at: https://screenshotone.com/
# Free tier: 100 screenshots/month
# Response time: 2-5 seconds
# REQUIRED if using screenshotone service
# 
# To get your key:
# 1. Visit https://screenshotone.com/
# 2. Sign up for free account
# 3. Copy your API key from dashboard
# 4. Paste it below (replace the placeholder)
SCREENSHOTONE_ACCESS_KEY=your_screenshotone_key_here

# ============================================
# urlscan.io API Key
# ============================================
# Get your free API key at: https://urlscan.io/ (login required)
# Free tier quotas (per day):
# - Public Scans: 5,000 (visible to everyone)
# - Unlisted Scans: 1,000 (visible to Pro users)
# - Private Scans: 50 (only visible to you)
# - Search Requests: 1,000
# Response time: 10-30 seconds
# REQUIRED if using urlscan service
#
# To get your key:
# 1. Visit https://urlscan.io/ and login
# 2. Go to Settings → API Keys
# 3. Generate a new key
# 4. Paste it below (replace the placeholder)
URLSCAN_API_KEY=your_urlscan_key_here

# ============================================
# Configuration Priority
# ============================================
# The skill checks for API keys in this order:
# 1. .rico-skills/.env (project-level, current directory)
# 2. ~/.rico-skills/.env (user-level, home directory)
# 
# If found in either location, it will be used automatically.
# If not found, you'll be prompted to set it up.
